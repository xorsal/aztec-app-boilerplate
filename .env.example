# Aztec node URL (default: http://localhost:8080)
PXE_URL=http://localhost:8080

# Ethereum L1 host for Anvil (default: http://localhost:8545)
ETHEREUM_HOST=http://localhost:8545

# Deployed Counter contract address (set after running `yarn deploy`)
VITE_CONTRACT_ADDRESS=

# Aztec node URL for the web frontend
VITE_AZTEC_NODE_URL=http://localhost:8080

# Chain ID for EIP-712 signing (default: 31337 for Anvil)
VITE_EIP712_CHAIN_ID=31337
