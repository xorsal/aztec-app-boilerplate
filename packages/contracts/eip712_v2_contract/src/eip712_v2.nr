/**
 * EIP-712 V2 Hash Functions for Aztec Account Contract
 *
 * V2 introduces variable argument types: each argument can be bytes32, uint256,
 * or address (instead of the fixed uint256[] in V1). This enables human-readable
 * display in MetaMask.
 *
 * A Merkle tree whitelist of valid type_hash(FunctionCall) values constrains
 * the oracle-provided type info, preventing a malicious frontend from crafting
 * structs that could mislead users.
 *
 * Per-call-count design: Each call slot has its own FunctionCallN->ArgumentsN type.
 * Separate entrypoint_1 through entrypoint_4 functions handle 1-4 calls.
 */

use std::meta::derive;
use keccak256::keccak256;
use ::aztec::oracle::capsules;
use ::aztec::authwit::entrypoint::FunctionCall;
use ::aztec::context::PrivateContext;
use ::aztec::protocol::{
    constants::{DOM_SEP__AUTHWIT_INNER, DOM_SEP__FUNCTION_ARGS, DOM_SEP__PUBLIC_CALLDATA, DOM_SEP__SIGNATURE_PAYLOAD},
    hash::{poseidon2_hash_subarray, poseidon2_hash_with_separator},
    merkle_tree::membership::{check_membership, MembershipWitness},
    traits::{Deserialize, Hash, Serialize},
    utils::{reader::Reader, writer::Writer},
};

// =============================================================================
// Constants
// =============================================================================

pub global MAX_SERIALIZED_ARGS: u32 = 20;
pub global MAX_SIGNATURE_SIZE: u32 = 128;
pub global MAX_ARGS_TYPE_STRING_LEN: u32 = 256;

// Merkle tree depth for Arguments whitelist
pub global MERKLE_DEPTH: u32 = 9;

// Capsule slots (must match TypeScript constants)
pub global EIP712_WITNESS_V2_1_SLOT: Field = 0x1234567890abcdf1;
pub global EIP712_WITNESS_V2_2_SLOT: Field = 0x1234567890abcdf2;
pub global EIP712_WITNESS_V2_3_SLOT: Field = 0x1234567890abcdf3;
pub global EIP712_WITNESS_V2_4_SLOT: Field = 0x1234567890abcdf4;
pub global EIP712_AUTHWIT_V2_SLOT: Field = 0xabcdef1234567891;

// =============================================================================
// Merkle Tree Roots (generated by scripts/generate-merkle-trees.ts)
// =============================================================================

// Per-slot FunctionCall Merkle roots (generated by scripts/generate-merkle-trees.ts)
pub global MERKLE_ROOT_FC_1: Field = 0x0633271a5313ed24c0224cb0c3b1c473a393aa19c1a2c085b816049fb0664c72;
pub global MERKLE_ROOT_FC_2: Field = 0x1fff6ffbccdd0193cd86f012093853422edad7dab5b6cc22d6c6b6d664151fe6;
pub global MERKLE_ROOT_FC_3: Field = 0x2c2ab955012fb60577f397a7cb81d49537ef371d368a42f3425d1944b0e4fa45;
pub global MERKLE_ROOT_FC_4: Field = 0x265613959ca7750afaa1fa7979a7ecdeed16fa1e9b437a5f86f576b99ab3bcf6;
// Root for "Arguments" tree (authwit) - keccak256(FC_AUTH_PRIMARY + args_type_string + AUTHWIT_APP_DOMAIN_DEF)
pub global MERKLE_ROOT_FC_AUTH: Field = 0x10ea5cfa7846f28e2c7d96cb47a4afcf26b710641d78e7aae894a04d53c2da7a;

/// Get the per-slot Merkle root for a given call index
pub fn get_merkle_root_fc(call_idx: u32) -> Field {
    if call_idx == 0 { MERKLE_ROOT_FC_1 }
    else if call_idx == 1 { MERKLE_ROOT_FC_2 }
    else if call_idx == 2 { MERKLE_ROOT_FC_3 }
    else { MERKLE_ROOT_FC_4 }
}

// =============================================================================
// Fixed Type Hashes
// =============================================================================

// keccak256("AccountData(bytes32 address,string walletName,string version)")
pub global ACCOUNT_DATA_TYPE_HASH: [u8; 32] = compute_keccak_type_hash_account_data();

// keccak256("TxMetadata(uint8 feePaymentMethod,bool cancellable,uint256 txNonce)")
pub global TX_METADATA_TYPE_HASH: [u8; 32] = compute_keccak_type_hash_tx_metadata();

// keccak256("AuthwitAppDomain(uint256 chainId,bytes32 verifyingContract)")
pub global AUTHWIT_APP_DOMAIN_TYPE_HASH: [u8; 32] = compute_keccak_type_hash_authwit_app_domain();

// =============================================================================
// Comptime String-to-Bytes Helper
// =============================================================================

comptime fn str_to_bytes<let N: u32>(s: str<N>) -> [u8; N] {
    let mut result: [u8; N] = [0; N];
    let bytes = s.as_bytes();
    for i in 0..N {
        result[i] = bytes[i];
    }
    result
}

// =============================================================================
// Per-Slot FunctionCall Primary Strings (124 chars each)
// =============================================================================

pub global FC1_PRIMARY: [u8; 124] = str_to_bytes("FunctionCall1(bytes32 contract,string functionSignature,Arguments1 arguments,bool isPublic,bool hideMsgSender,bool isStatic)");
pub global FC1_PRIMARY_LEN: u32 = 124;

pub global FC2_PRIMARY: [u8; 124] = str_to_bytes("FunctionCall2(bytes32 contract,string functionSignature,Arguments2 arguments,bool isPublic,bool hideMsgSender,bool isStatic)");
pub global FC2_PRIMARY_LEN: u32 = 124;

pub global FC3_PRIMARY: [u8; 124] = str_to_bytes("FunctionCall3(bytes32 contract,string functionSignature,Arguments3 arguments,bool isPublic,bool hideMsgSender,bool isStatic)");
pub global FC3_PRIMARY_LEN: u32 = 124;

pub global FC4_PRIMARY: [u8; 124] = str_to_bytes("FunctionCall4(bytes32 contract,string functionSignature,Arguments4 arguments,bool isPublic,bool hideMsgSender,bool isStatic)");
pub global FC4_PRIMARY_LEN: u32 = 124;

// =============================================================================
// Per-N EntrypointAuthorization Primary Strings
// =============================================================================

pub global ENTRYPOINT_AUTH_PRIMARY_1: [u8; 98] = str_to_bytes("EntrypointAuthorization(AccountData accountData,FunctionCall1 functionCall1,TxMetadata txMetadata)");
pub global ENTRYPOINT_AUTH_PRIMARY_1_LEN: u32 = 98;

pub global ENTRYPOINT_AUTH_PRIMARY_2: [u8; 126] = str_to_bytes("EntrypointAuthorization(AccountData accountData,FunctionCall1 functionCall1,FunctionCall2 functionCall2,TxMetadata txMetadata)");
pub global ENTRYPOINT_AUTH_PRIMARY_2_LEN: u32 = 126;

pub global ENTRYPOINT_AUTH_PRIMARY_3: [u8; 154] = str_to_bytes("EntrypointAuthorization(AccountData accountData,FunctionCall1 functionCall1,FunctionCall2 functionCall2,FunctionCall3 functionCall3,TxMetadata txMetadata)");
pub global ENTRYPOINT_AUTH_PRIMARY_3_LEN: u32 = 154;

pub global ENTRYPOINT_AUTH_PRIMARY_4: [u8; 182] = str_to_bytes("EntrypointAuthorization(AccountData accountData,FunctionCall1 functionCall1,FunctionCall2 functionCall2,FunctionCall3 functionCall3,FunctionCall4 functionCall4,TxMetadata txMetadata)");
pub global ENTRYPOINT_AUTH_PRIMARY_4_LEN: u32 = 182;

// =============================================================================
// Fixed Referenced Type Definitions
// =============================================================================

pub global ACCOUNT_DATA_DEF: [u8; 61] = str_to_bytes("AccountData(bytes32 address,string walletName,string version)");
pub global ACCOUNT_DATA_DEF_LEN: u32 = 61;

pub global TX_METADATA_DEF: [u8; 67] = str_to_bytes("TxMetadata(uint8 feePaymentMethod,bool cancellable,uint256 txNonce)");
pub global TX_METADATA_DEF_LEN: u32 = 67;

pub global FC_AUTH_PRIMARY: [u8; 129] = str_to_bytes("FunctionCallAuthorization(AuthwitAppDomain appDomain,bytes32 contract,string functionSignature,Arguments arguments,bool isPublic)");
pub global FC_AUTH_PRIMARY_LEN: u32 = 129;

pub global AUTHWIT_APP_DOMAIN_DEF: [u8; 59] = str_to_bytes("AuthwitAppDomain(uint256 chainId,bytes32 verifyingContract)");
pub global AUTHWIT_APP_DOMAIN_DEF_LEN: u32 = 59;

// =============================================================================
// Comptime Type Hash Computation
// =============================================================================

comptime fn compute_keccak_type_hash_account_data() -> [u8; 32] {
    let s = str_to_bytes("AccountData(bytes32 address,string walletName,string version)");
    keccak256(s, 61)
}

comptime fn compute_keccak_type_hash_tx_metadata() -> [u8; 32] {
    let s = str_to_bytes("TxMetadata(uint8 feePaymentMethod,bool cancellable,uint256 txNonce)");
    keccak256(s, 67)
}

comptime fn compute_keccak_type_hash_authwit_app_domain() -> [u8; 32] {
    let s = str_to_bytes("AuthwitAppDomain(uint256 chainId,bytes32 verifyingContract)");
    keccak256(s, 59)
}

// =============================================================================
// AppPayload Structs (per-N)
// =============================================================================

pub global FUNCTION_CALL_SERIALIZED_LEN: u32 = 6;
pub global APP_PAYLOAD_1_SERIALIZED_LEN: u32 = 7;
pub global APP_PAYLOAD_2_SERIALIZED_LEN: u32 = 13;
pub global APP_PAYLOAD_3_SERIALIZED_LEN: u32 = 19;
pub global APP_PAYLOAD_4_SERIALIZED_LEN: u32 = 25;

#[derive(Serialize)]
pub struct AppPayload1 {
    function_calls: [FunctionCall; 1],
    pub tx_nonce: Field,
}

impl Hash for AppPayload1 {
    fn hash(self) -> Field {
        poseidon2_hash_with_separator(self.serialize(), DOM_SEP__SIGNATURE_PAYLOAD)
    }
}

impl AppPayload1 {
    pub fn execute_calls(self, context: &mut PrivateContext) {
        for call in self.function_calls {
            if !call.target_address.is_zero() {
                if call.is_public {
                    context.call_public_function_with_calldata_hash(
                        call.target_address, call.args_hash, call.is_static, call.hide_msg_sender,
                    );
                } else {
                    assert(!call.hide_msg_sender, "Incompatible flag. `hide_msg_sender = true` is only available for public calls.");
                    let _result = context.call_private_function_with_args_hash(
                        call.target_address, call.function_selector, call.args_hash, call.is_static,
                    );
                }
            }
        }
    }
}

