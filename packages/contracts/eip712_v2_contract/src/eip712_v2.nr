/**
 * EIP-712 V2 Hash Functions for Aztec Account Contract
 *
 * V2 introduces variable argument types: each argument can be bytes32, uint256,
 * or int256 (instead of the fixed uint256[] in V1). This enables human-readable
 * display in MetaMask.
 *
 * A Merkle tree whitelist of valid type_hash(FunctionCall) values constrains
 * the oracle-provided type info, preventing a malicious frontend from crafting
 * structs that could mislead users.
 *
 * Unified design: All call slots share a single FunctionCall->Arguments type.
 * ACCOUNT_MAX_CALLS=4 allows 3 business calls + 1 SponsoredFPC slot.
 */

use std::meta::derive;
use keccak256::keccak256;
use ::aztec::oracle::capsules;
use ::aztec::authwit::entrypoint::FunctionCall;
use ::aztec::context::PrivateContext;
use ::aztec::protocol::{
    constants::{DOM_SEP__AUTHWIT_INNER, DOM_SEP__FUNCTION_ARGS, DOM_SEP__PUBLIC_CALLDATA, DOM_SEP__SIGNATURE_PAYLOAD},
    hash::{poseidon2_hash_subarray, poseidon2_hash_with_separator},
    merkle_tree::membership::{check_membership, MembershipWitness},
    traits::{Deserialize, Hash, Serialize},
    utils::{reader::Reader, writer::Writer},
};

// =============================================================================
// Constants
// =============================================================================

pub global MAX_SERIALIZED_ARGS: u32 = 20;
pub global MAX_SIGNATURE_SIZE: u32 = 128;
pub global ACCOUNT_MAX_CALLS: u32 = 4; // Unified: 4 calls (3 business + 1 FPC)
pub global MAX_ARGS_TYPE_STRING_LEN: u32 = 256;

// Merkle tree depth for Arguments whitelist
pub global MERKLE_DEPTH: u32 = 17;

// Capsule slots (must match TypeScript constants)
pub global EIP712_WITNESS_V2_2_SLOT: Field = 0x1234567890abcdf1;
pub global EIP712_AUTHWIT_V2_SLOT: Field = 0xabcdef1234567891;

// =============================================================================
// Merkle Tree Roots (generated by scripts/generate-merkle-trees.ts)
// =============================================================================

// Root for "FunctionCall" tree (entrypoint) - keccak256(FC_PRIMARY + args_type_string)
// Placeholder until Merkle trees are regenerated
pub global MERKLE_ROOT_FC: Field = 0x2f6722fe2ae340afcb0448978e464debf48ad5451f647b24f2aec095f59eeb11;
// Root for "Arguments" tree (authwit) - keccak256(FC_AUTH_PRIMARY + args_type_string + AUTHWIT_APP_DOMAIN_DEF)
pub global MERKLE_ROOT_FC_AUTH: Field = 0x054a9fe2ce02ae6f96b01ea4962e3d41b2da0856e4027a2e2c53cf04c3271eda;

// =============================================================================
// Fixed Type Hashes
// =============================================================================

// keccak256("AccountData(bytes32 address,string walletName,string version)")
pub global ACCOUNT_DATA_TYPE_HASH: [u8; 32] = compute_keccak_type_hash_account_data();

// keccak256("TxMetadata(uint8 feePaymentMethod,bool cancellable,uint256 txNonce)")
pub global TX_METADATA_TYPE_HASH: [u8; 32] = compute_keccak_type_hash_tx_metadata();

// keccak256("AuthwitAppDomain(uint256 chainId,bytes32 verifyingContract)")
pub global AUTHWIT_APP_DOMAIN_TYPE_HASH: [u8; 32] = compute_keccak_type_hash_authwit_app_domain();

// =============================================================================
// Comptime String-to-Bytes Helper
// =============================================================================

comptime fn str_to_bytes<let N: u32>(s: str<N>) -> [u8; N] {
    let mut result: [u8; N] = [0; N];
    let bytes = s.as_bytes();
    for i in 0..N {
        result[i] = bytes[i];
    }
    result
}

// =============================================================================
// Primary Struct Strings (unified - single FunctionCall type for all slots)
// =============================================================================

pub global ENTRYPOINT_AUTH_PRIMARY: [u8; 178] = str_to_bytes("EntrypointAuthorization(AccountData accountData,FunctionCall functionCall1,FunctionCall functionCall2,FunctionCall functionCall3,FunctionCall functionCall4,TxMetadata txMetadata)");
pub global ENTRYPOINT_AUTH_PRIMARY_LEN: u32 = 178;

pub global FC_PRIMARY: [u8; 122] = str_to_bytes("FunctionCall(bytes32 contract,string functionSignature,Arguments arguments,bool isPublic,bool hideMsgSender,bool isStatic)");
pub global FC_PRIMARY_LEN: u32 = 122;

// Fixed referenced type definitions (for building encode_type)
pub global ACCOUNT_DATA_DEF: [u8; 61] = str_to_bytes("AccountData(bytes32 address,string walletName,string version)");
pub global ACCOUNT_DATA_DEF_LEN: u32 = 61;

pub global TX_METADATA_DEF: [u8; 67] = str_to_bytes("TxMetadata(uint8 feePaymentMethod,bool cancellable,uint256 txNonce)");
pub global TX_METADATA_DEF_LEN: u32 = 67;

pub global FC_AUTH_PRIMARY: [u8; 129] = str_to_bytes("FunctionCallAuthorization(AuthwitAppDomain appDomain,bytes32 contract,string functionSignature,Arguments arguments,bool isPublic)");
pub global FC_AUTH_PRIMARY_LEN: u32 = 129;

pub global AUTHWIT_APP_DOMAIN_DEF: [u8; 59] = str_to_bytes("AuthwitAppDomain(uint256 chainId,bytes32 verifyingContract)");
pub global AUTHWIT_APP_DOMAIN_DEF_LEN: u32 = 59;

// =============================================================================
// Comptime Type Hash Computation
// =============================================================================

comptime fn compute_keccak_type_hash_account_data() -> [u8; 32] {
    let s = str_to_bytes("AccountData(bytes32 address,string walletName,string version)");
    keccak256(s, 61)
}

comptime fn compute_keccak_type_hash_tx_metadata() -> [u8; 32] {
    let s = str_to_bytes("TxMetadata(uint8 feePaymentMethod,bool cancellable,uint256 txNonce)");
    keccak256(s, 67)
}

comptime fn compute_keccak_type_hash_authwit_app_domain() -> [u8; 32] {
    let s = str_to_bytes("AuthwitAppDomain(uint256 chainId,bytes32 verifyingContract)");
    keccak256(s, 59)
}

// =============================================================================
// Custom AppPayload with 4 calls
// =============================================================================

#[derive(Serialize)]
pub struct AppPayload2 {
    function_calls: [FunctionCall; ACCOUNT_MAX_CALLS],
    pub tx_nonce: Field,
}

impl Hash for AppPayload2 {
    fn hash(self) -> Field {
        poseidon2_hash_with_separator(self.serialize(), DOM_SEP__SIGNATURE_PAYLOAD)
    }
}

impl AppPayload2 {
    pub fn execute_calls(self, context: &mut PrivateContext) {
        for call in self.function_calls {
            if !call.target_address.is_zero() {
                if call.is_public {
                    context.call_public_function_with_calldata_hash(
                        call.target_address,
                        call.args_hash,
                        call.is_static,
                        call.hide_msg_sender,
                    );
                } else {
                    assert(
                        !call.hide_msg_sender,
                        "Incompatible flag. `hide_msg_sender = true` is only available for public calls.",
                    );
                    let _result = context.call_private_function_with_args_hash(
                        call.target_address,
                        call.function_selector,
                        call.args_hash,
                        call.is_static,
                    );
                }
            }
        }
    }
}

// =============================================================================
// V2 Witness Structure (unified - shared type data across all call slots)
// =============================================================================

/// EIP-712 V2 witness data for 4 function calls with unified FunctionCall type.
///
/// New layout (175 fields):
///   [0-2]:     Signature (3)
///   [3-130]:   4 calls x 32 fields (128)
///   [131-162]: Shared type/proof data (32)
///   [163-174]: Metadata (12)
pub struct Eip712WitnessV2_2 {
    // ECDSA signature (r || s), 64 bytes
    pub signature_r: [u8; 32],
    pub signature_s: [u8; 32],

    // Per-call data (4 function calls), each 32 fields:
    //   func_sig(5) + sig_len(1) + args(20) + args_len(1) + target(1)
    //   + is_public(1) + hide_msg_sender(1) + is_static(1) + padding(1)
    pub function_signatures: [[u8; MAX_SIGNATURE_SIZE]; ACCOUNT_MAX_CALLS],
    pub signature_lengths: [u32; ACCOUNT_MAX_CALLS],
    pub function_args: [[Field; MAX_SERIALIZED_ARGS]; ACCOUNT_MAX_CALLS],
    pub args_lengths: [u32; ACCOUNT_MAX_CALLS],
    pub target_addresses: [Field; ACCOUNT_MAX_CALLS],
    pub is_public: [bool; ACCOUNT_MAX_CALLS],
    pub hide_msg_sender: [bool; ACCOUNT_MAX_CALLS],
    pub is_static: [bool; ACCOUNT_MAX_CALLS],

    // Shared type/proof data (32 fields):
    //   type_str(9) + type_str_len(1) + proof(17) + leaf_idx(1) + fc_type_hash(2) + args_type_hash(2)
    pub args_type_string: [u8; MAX_ARGS_TYPE_STRING_LEN],
    pub args_type_string_length: u32,
    pub merkle_proof: [Field; MERKLE_DEPTH],
    pub merkle_leaf_index: Field,
    pub fc_type_hash: [u8; 32],
    pub args_type_hash: [u8; 32],

    // Metadata (12 fields):
    //   wallet_name(5) + wallet_name_len(1) + wallet_version(2) + wallet_version_len(1)
    //   + account_address(1) + chain_id(1) + padding(1)
    pub wallet_name: [u8; MAX_SIGNATURE_SIZE],
    pub wallet_name_length: u32,
    pub wallet_version: [u8; 32],
    pub wallet_version_length: u32,
    pub account_address: Field,
    pub chain_id: Field,
}

// Serialization size: 3 + 4*32 + 32 + 12 = 175 fields
pub global EIP712_WITNESS_V2_2_SERIALIZED_LEN: u32 = 175;

impl Serialize for Eip712WitnessV2_2 {
    let N: u32 = EIP712_WITNESS_V2_2_SERIALIZED_LEN;

    fn serialize(self) -> [Field; Self::N] {
        let mut result: [Field; EIP712_WITNESS_V2_2_SERIALIZED_LEN] = [0; EIP712_WITNESS_V2_2_SERIALIZED_LEN];

        // [0-2]: Signature (64 bytes: 31+31+2)
        result[0] = pack_bytes_31(self.signature_r, 0);
        let mut combined: [u8; 31] = [0; 31];
        combined[0] = self.signature_r[31];
        for i in 0..30 {
            combined[i + 1] = self.signature_s[i];
        }
        result[1] = pack_bytes_to_field(combined);
        result[2] = (self.signature_s[30] as Field) * 256 + (self.signature_s[31] as Field);

        // [3-130]: 4 calls, each 32 fields
        for call_idx in 0..ACCOUNT_MAX_CALLS {
            let base = 3 + call_idx * 32;

            // Function signature (128 bytes = 5 fields: 31+31+31+31+4)
            for i in 0..4 {
                let mut chunk: [u8; 31] = [0; 31];
                for j in 0..31 {
                    chunk[j] = self.function_signatures[call_idx][i * 31 + j];
                }
                result[base + i] = pack_bytes_to_field(chunk);
            }
            let mut last_chunk: Field = 0;
            for i in 0..4 {
                last_chunk = last_chunk * 256 + (self.function_signatures[call_idx][124 + i] as Field);
            }
            result[base + 4] = last_chunk;

            // Signature length
            result[base + 5] = self.signature_lengths[call_idx] as Field;

            // Function args (20 fields)
            for i in 0..MAX_SERIALIZED_ARGS {
                result[base + 6 + i] = self.function_args[call_idx][i];
            }

            // Args length
            result[base + 26] = self.args_lengths[call_idx] as Field;

            // Target address
            result[base + 27] = self.target_addresses[call_idx];

            // is_public, hide_msg_sender, is_static
            result[base + 28] = self.is_public[call_idx] as Field;
            result[base + 29] = self.hide_msg_sender[call_idx] as Field;
            result[base + 30] = self.is_static[call_idx] as Field;

            // Padding
            result[base + 31] = 0;
        }

        // [131-162]: Shared type/proof data (32 fields)
        // Args type string (256 bytes = 9 fields: 8x31 + 1x8)
        for i in 0..8 {
            let mut chunk: [u8; 31] = [0; 31];
            for j in 0..31 {
                chunk[j] = self.args_type_string[i * 31 + j];
            }
            result[131 + i] = pack_bytes_to_field(chunk);
        }
        let mut last_ts: Field = 0;
        for i in 0..8 {
            last_ts = last_ts * 256 + (self.args_type_string[248 + i] as Field);
        }
        result[139] = last_ts;

        // Args type string length
        result[140] = self.args_type_string_length as Field;

        // Merkle proof (17 fields)
        for i in 0..MERKLE_DEPTH {
            result[141 + i] = self.merkle_proof[i];
        }

        // Merkle leaf index
        result[158] = self.merkle_leaf_index;

        // FunctionCall type hash (32 bytes = 2 fields: 31+1)
        result[159] = pack_bytes_31(self.fc_type_hash, 0);
        result[160] = self.fc_type_hash[31] as Field;

        // Arguments type hash (32 bytes = 2 fields: 31+1)
        result[161] = pack_bytes_31(self.args_type_hash, 0);
        result[162] = self.args_type_hash[31] as Field;

        // [163-174]: Metadata (12 fields)
        // wallet_name (128 bytes = 5 fields)
        for i in 0..4 {
            let mut chunk: [u8; 31] = [0; 31];
            for j in 0..31 {
                chunk[j] = self.wallet_name[i * 31 + j];
            }
            result[163 + i] = pack_bytes_to_field(chunk);
        }
        let mut wn_last: Field = 0;
        for i in 0..4 {
            wn_last = wn_last * 256 + (self.wallet_name[124 + i] as Field);
        }
        result[167] = wn_last;

        // wallet_name_length
        result[168] = self.wallet_name_length as Field;

        // wallet_version (32 bytes = 2 fields: 31+1)
        result[169] = pack_bytes_31(self.wallet_version, 0);
        result[170] = self.wallet_version[31] as Field;

        // wallet_version_length
        result[171] = self.wallet_version_length as Field;

        // account_address
        result[172] = self.account_address;

        // chain_id
        result[173] = self.chain_id;

        // padding
        result[174] = 0;

        result
    }

    fn stream_serialize<let K: u32>(self, writer: &mut Writer<K>) {
        let serialized = self.serialize();
        writer.write_array(serialized);
    }
}

impl Deserialize for Eip712WitnessV2_2 {
    let N: u32 = EIP712_WITNESS_V2_2_SERIALIZED_LEN;

    fn deserialize(fields: [Field; Self::N]) -> Self {
        // [0-2]: Signature
        let sig_bytes = unpack_signature_from_fields([fields[0], fields[1], fields[2]]);
        let mut signature_r: [u8; 32] = [0; 32];
        let mut signature_s: [u8; 32] = [0; 32];
        for i in 0..32 {
            signature_r[i] = sig_bytes[i];
            signature_s[i] = sig_bytes[32 + i];
        }

        let mut function_signatures: [[u8; MAX_SIGNATURE_SIZE]; ACCOUNT_MAX_CALLS] = [[0; MAX_SIGNATURE_SIZE]; ACCOUNT_MAX_CALLS];
        let mut signature_lengths: [u32; ACCOUNT_MAX_CALLS] = [0; ACCOUNT_MAX_CALLS];
        let mut function_args: [[Field; MAX_SERIALIZED_ARGS]; ACCOUNT_MAX_CALLS] = [[0; MAX_SERIALIZED_ARGS]; ACCOUNT_MAX_CALLS];
        let mut args_lengths: [u32; ACCOUNT_MAX_CALLS] = [0; ACCOUNT_MAX_CALLS];
        let mut target_addresses: [Field; ACCOUNT_MAX_CALLS] = [0; ACCOUNT_MAX_CALLS];
        let mut is_public: [bool; ACCOUNT_MAX_CALLS] = [false; ACCOUNT_MAX_CALLS];
        let mut hide_msg_sender: [bool; ACCOUNT_MAX_CALLS] = [false; ACCOUNT_MAX_CALLS];
        let mut is_static: [bool; ACCOUNT_MAX_CALLS] = [false; ACCOUNT_MAX_CALLS];

        // [3-130]: 4 calls, each 32 fields
        for call_idx in 0..ACCOUNT_MAX_CALLS {
            let base = 3 + call_idx * 32;

            // Function signature
            function_signatures[call_idx] = unpack_func_sig_from_fields([
                fields[base], fields[base + 1], fields[base + 2], fields[base + 3], fields[base + 4],
            ]);
            signature_lengths[call_idx] = fields[base + 5] as u32;

            // Function args
            for i in 0..MAX_SERIALIZED_ARGS {
                function_args[call_idx][i] = fields[base + 6 + i];
            }
            args_lengths[call_idx] = fields[base + 26] as u32;
            target_addresses[call_idx] = fields[base + 27];

            is_public[call_idx] = fields[base + 28] == 1;
            hide_msg_sender[call_idx] = fields[base + 29] == 1;
            is_static[call_idx] = fields[base + 30] == 1;
        }

        // [131-162]: Shared type/proof data
        // Args type string (9 fields: 8x31 + 1x8)
        let mut args_type_string: [u8; MAX_ARGS_TYPE_STRING_LEN] = [0; MAX_ARGS_TYPE_STRING_LEN];
        for i in 0..8 {
            let bytes: [u8; 31] = fields[131 + i].to_be_bytes();
            for j in 0..31 {
                args_type_string[i * 31 + j] = bytes[j];
            }
        }
        let last_ts: [u8; 8] = fields[139].to_be_bytes();
        for i in 0..8 {
            args_type_string[248 + i] = last_ts[i];
        }
        let args_type_string_length = fields[140] as u32;

        // Merkle proof
        let mut merkle_proof: [Field; MERKLE_DEPTH] = [0; MERKLE_DEPTH];
        for i in 0..MERKLE_DEPTH {
            merkle_proof[i] = fields[141 + i];
        }
        let merkle_leaf_index = fields[158];

        // FunctionCall type hash
        let fc_th_bytes: [u8; 31] = fields[159].to_be_bytes();
        let mut fc_type_hash: [u8; 32] = [0; 32];
        for j in 0..31 {
            fc_type_hash[j] = fc_th_bytes[j];
        }
        fc_type_hash[31] = fields[160].to_be_bytes::<32>()[31];

        // Arguments type hash
        let args_th_bytes: [u8; 31] = fields[161].to_be_bytes();
        let mut args_type_hash: [u8; 32] = [0; 32];
        for j in 0..31 {
            args_type_hash[j] = args_th_bytes[j];
        }
        args_type_hash[31] = fields[162].to_be_bytes::<32>()[31];

        // [163-174]: Metadata
        // wallet_name
        let mut wallet_name: [u8; MAX_SIGNATURE_SIZE] = [0; MAX_SIGNATURE_SIZE];
        let wn = unpack_func_sig_from_fields([fields[163], fields[164], fields[165], fields[166], fields[167]]);
        for i in 0..MAX_SIGNATURE_SIZE {
            wallet_name[i] = wn[i];
        }
        let wallet_name_length = fields[168] as u32;

        // wallet_version
        let mut wallet_version: [u8; 32] = [0; 32];
        let wv_bytes: [u8; 31] = fields[169].to_be_bytes();
        for i in 0..31 {
            wallet_version[i] = wv_bytes[i];
        }
        wallet_version[31] = fields[170].to_be_bytes::<32>()[31];
        let wallet_version_length = fields[171] as u32;

        let account_address = fields[172];
        let chain_id = fields[173];

        Eip712WitnessV2_2 {
            signature_r,
            signature_s,
            function_signatures,
            signature_lengths,
            function_args,
            args_lengths,
            target_addresses,
            is_public,
            hide_msg_sender,
            is_static,
            args_type_string,
            args_type_string_length,
            merkle_proof,
            merkle_leaf_index,
            fc_type_hash,
            args_type_hash,
            wallet_name,
            wallet_name_length,
            wallet_version,
            wallet_version_length,
            account_address,
            chain_id,
        }
    }

    fn stream_deserialize<let K: u32>(reader: &mut Reader<K>) -> Self {
        let fields: [Field; EIP712_WITNESS_V2_2_SERIALIZED_LEN] = reader.read_array();
        Deserialize::deserialize(fields)
    }
}

/// Load V2 witness for 4 calls from capsule storage
pub unconstrained fn load_eip712_witness_v2_2(
    contract_address: ::aztec::protocol::address::AztecAddress,
) -> Option<Eip712WitnessV2_2> {
    capsules::load(contract_address, EIP712_WITNESS_V2_2_SLOT)
}

// =============================================================================
// V2 Authwit Witness Structure (unchanged - authwit is always single-call)
// =============================================================================

/// EIP-712 V2 witness data for individual authorization (authwit)
pub struct Eip712AuthwitWitnessV2 {
    pub signature_r: [u8; 32],
    pub signature_s: [u8; 32],

    pub function_signature: [u8; MAX_SIGNATURE_SIZE],
    pub signature_length: u32,
    pub function_args: [Field; MAX_SERIALIZED_ARGS],
    pub args_length: u32,
    pub target_address: Field,
    pub is_public: bool,

    // Variable args type info
    pub args_type_string: [u8; MAX_ARGS_TYPE_STRING_LEN],
    pub args_type_string_length: u32,

    // Merkle proof
    pub merkle_proof: [Field; MERKLE_DEPTH],
    pub merkle_leaf_index: Field,

    // Authwit-specific domain
    pub chain_id: Field,
    pub verifying_contract: Field,
    pub inner_hash: Field,

    // Pre-computed type hashes from oracle
    pub fc_auth_type_hash: [u8; 32],
    pub args_type_hash: [u8; 32],
}

pub global EIP712_AUTHWIT_V2_SERIALIZED_LEN: u32 = 67;

impl Serialize for Eip712AuthwitWitnessV2 {
    let N: u32 = EIP712_AUTHWIT_V2_SERIALIZED_LEN;

    fn serialize(self) -> [Field; Self::N] {
        let mut result: [Field; EIP712_AUTHWIT_V2_SERIALIZED_LEN] = [0; EIP712_AUTHWIT_V2_SERIALIZED_LEN];

        // [0-2]: Signature
        result[0] = pack_bytes_31(self.signature_r, 0);
        let mut combined: [u8; 31] = [0; 31];
        combined[0] = self.signature_r[31];
        for i in 0..30 {
            combined[i + 1] = self.signature_s[i];
        }
        result[1] = pack_bytes_to_field(combined);
        result[2] = (self.signature_s[30] as Field) * 256 + (self.signature_s[31] as Field);

        // [3-7]: Function signature
        for i in 0..4 {
            let mut chunk: [u8; 31] = [0; 31];
            for j in 0..31 {
                chunk[j] = self.function_signature[i * 31 + j];
            }
            result[3 + i] = pack_bytes_to_field(chunk);
        }
        let mut last_chunk: Field = 0;
        for i in 0..4 {
            last_chunk = last_chunk * 256 + (self.function_signature[124 + i] as Field);
        }
        result[7] = last_chunk;

        // [8]: Signature length
        result[8] = self.signature_length as Field;

        // [9-28]: Function args
        for i in 0..MAX_SERIALIZED_ARGS {
            result[9 + i] = self.function_args[i];
        }

        // [29]: Args length
        result[29] = self.args_length as Field;

        // [30]: Target address
        result[30] = self.target_address;

        // [31]: is_public
        result[31] = self.is_public as Field;

        // [32-40]: Args type string (9 fields: 8x31 + 1x8)
        for i in 0..8 {
            let mut chunk: [u8; 31] = [0; 31];
            for j in 0..31 {
                chunk[j] = self.args_type_string[i * 31 + j];
            }
            result[32 + i] = pack_bytes_to_field(chunk);
        }
        let mut last_ts: Field = 0;
        for i in 0..8 {
            last_ts = last_ts * 256 + (self.args_type_string[248 + i] as Field);
        }
        result[40] = last_ts;

        // [41]: Args type string length
        result[41] = self.args_type_string_length as Field;

        // [42-58]: Merkle proof
        for i in 0..MERKLE_DEPTH {
            result[42 + i] = self.merkle_proof[i];
        }

        // [59]: Merkle leaf index
        result[59] = self.merkle_leaf_index;

        // [60]: Chain ID
        result[60] = self.chain_id;

        // [61]: Verifying contract
        result[61] = self.verifying_contract;

        // [62]: Inner hash
        result[62] = self.inner_hash;

        // [63-64]: fc_auth_type_hash
        result[63] = pack_bytes_31(self.fc_auth_type_hash, 0);
        result[64] = self.fc_auth_type_hash[31] as Field;

        // [65-66]: args_type_hash
        result[65] = pack_bytes_31(self.args_type_hash, 0);
        result[66] = self.args_type_hash[31] as Field;

        result
    }

    fn stream_serialize<let K: u32>(self, writer: &mut Writer<K>) {
        let serialized = self.serialize();
        writer.write_array(serialized);
    }
}

impl Deserialize for Eip712AuthwitWitnessV2 {
    let N: u32 = EIP712_AUTHWIT_V2_SERIALIZED_LEN;

    fn deserialize(fields: [Field; Self::N]) -> Self {
        let sig_bytes = unpack_signature_from_fields([fields[0], fields[1], fields[2]]);
        let mut signature_r: [u8; 32] = [0; 32];
        let mut signature_s: [u8; 32] = [0; 32];
        for i in 0..32 {
            signature_r[i] = sig_bytes[i];
            signature_s[i] = sig_bytes[32 + i];
        }

        let function_signature = unpack_func_sig_from_fields([fields[3], fields[4], fields[5], fields[6], fields[7]]);
        let signature_length = fields[8] as u32;

        let mut function_args: [Field; MAX_SERIALIZED_ARGS] = [0; MAX_SERIALIZED_ARGS];
        for i in 0..MAX_SERIALIZED_ARGS {
            function_args[i] = fields[9 + i];
        }
        let args_length = fields[29] as u32;
        let target_address = fields[30];
        let is_public = fields[31] == 1;

        // Args type string
        let mut args_type_string: [u8; MAX_ARGS_TYPE_STRING_LEN] = [0; MAX_ARGS_TYPE_STRING_LEN];
        for i in 0..8 {
            let bytes: [u8; 31] = fields[32 + i].to_be_bytes();
            for j in 0..31 {
                args_type_string[i * 31 + j] = bytes[j];
            }
        }
        let last_ts: [u8; 8] = fields[40].to_be_bytes();
        for i in 0..8 {
            args_type_string[248 + i] = last_ts[i];
        }
        let args_type_string_length = fields[41] as u32;

        let mut merkle_proof: [Field; MERKLE_DEPTH] = [0; MERKLE_DEPTH];
        for i in 0..MERKLE_DEPTH {
            merkle_proof[i] = fields[42 + i];
        }
        let merkle_leaf_index = fields[59];

        let chain_id = fields[60];
        let verifying_contract = fields[61];
        let inner_hash = fields[62];

        let fc_auth_th: [u8; 31] = fields[63].to_be_bytes();
        let mut fc_auth_type_hash: [u8; 32] = [0; 32];
        for i in 0..31 {
            fc_auth_type_hash[i] = fc_auth_th[i];
        }
        fc_auth_type_hash[31] = fields[64].to_be_bytes::<32>()[31];

        let args_th: [u8; 31] = fields[65].to_be_bytes();
        let mut args_type_hash: [u8; 32] = [0; 32];
        for i in 0..31 {
            args_type_hash[i] = args_th[i];
        }
        args_type_hash[31] = fields[66].to_be_bytes::<32>()[31];

        Eip712AuthwitWitnessV2 {
            signature_r,
            signature_s,
            function_signature,
            signature_length,
            function_args,
            args_length,
            target_address,
            is_public,
            args_type_string,
            args_type_string_length,
            merkle_proof,
            merkle_leaf_index,
            chain_id,
            verifying_contract,
            inner_hash,
            fc_auth_type_hash,
            args_type_hash,
        }
    }

    fn stream_deserialize<let K: u32>(reader: &mut Reader<K>) -> Self {
        let fields: [Field; EIP712_AUTHWIT_V2_SERIALIZED_LEN] = reader.read_array();
        Deserialize::deserialize(fields)
    }
}

/// Load V2 authwit witness from capsule storage
pub unconstrained fn load_eip712_authwit_witness_v2(
    contract_address: ::aztec::protocol::address::AztecAddress,
) -> Option<Eip712AuthwitWitnessV2> {
    capsules::load(contract_address, EIP712_AUTHWIT_V2_SLOT)
}

// =============================================================================
// Byte Packing/Unpacking Helpers
// =============================================================================

fn pack_bytes_31<let N: u32>(bytes: [u8; N], offset: u32) -> Field {
    let mut result: Field = 0;
    for i in 0..31 {
        if offset + i < N {
            result = result * 256 + (bytes[offset + i] as Field);
        }
    }
    result
}

fn pack_bytes_to_field(bytes: [u8; 31]) -> Field {
    let mut result: Field = 0;
    for i in 0..31 {
        result = result * 256 + (bytes[i] as Field);
    }
    result
}

fn unpack_signature_from_fields(fields: [Field; 3]) -> [u8; 64] {
    let mut sig: [u8; 64] = [0; 64];
    let b0: [u8; 31] = fields[0].to_be_bytes();
    for i in 0..31 {
        sig[i] = b0[i];
    }
    let b1: [u8; 31] = fields[1].to_be_bytes();
    for i in 0..31 {
        sig[31 + i] = b1[i];
    }
    let b2: [u8; 2] = fields[2].to_be_bytes();
    sig[62] = b2[0];
    sig[63] = b2[1];
    sig
}

fn unpack_func_sig_from_fields(fields: [Field; 5]) -> [u8; MAX_SIGNATURE_SIZE] {
    let mut func_sig: [u8; MAX_SIGNATURE_SIZE] = [0; MAX_SIGNATURE_SIZE];
    for f in 0..4 {
        let bytes: [u8; 31] = fields[f].to_be_bytes();
        for i in 0..31 {
            func_sig[f * 31 + i] = bytes[i];
        }
    }
    let last: [u8; 4] = fields[4].to_be_bytes();
    for i in 0..4 {
        func_sig[124 + i] = last[i];
    }
    func_sig
}

// =============================================================================
// EIP-712 V2 Hash Functions
// =============================================================================

/// Hash a dynamic-length string for EIP-712 encoding: enc(string) = keccak256(string)
pub fn hash_string<let N: u32>(data: [u8; N], len: u32) -> [u8; 32] {
    keccak256(data, len)
}

/// Convert a Field to 32-byte big-endian representation
pub fn field_to_bytes32(f: Field) -> [u8; 32] {
    f.to_be_bytes()
}

/// Compute type_hash from a type string: keccak256(type_string)
pub fn compute_type_hash<let N: u32>(type_string: [u8; N], len: u32) -> [u8; 32] {
    keccak256(type_string, len)
}

/// Convert a 32-byte type_hash to a Field for Merkle tree lookup.
pub fn type_hash_to_field(type_hash: [u8; 32]) -> Field {
    let mut result: Field = 0;
    for i in 0..32 {
        result = result * 256 + (type_hash[i] as Field);
    }
    result
}

/// Verify that a type_hash is in the Merkle tree whitelist
pub fn verify_arguments_whitelist(
    type_hash_field: Field,
    proof: [Field; MERKLE_DEPTH],
    leaf_index: Field,
    root: Field,
) {
    let witness = MembershipWitness { leaf_index, sibling_path: proof };
    assert(
        check_membership(type_hash_field, witness, root),
        "Arguments type_hash not in whitelist",
    );
}

/// Compute hashStruct(Arguments) with variable types.
/// All types (bytes32, uint256, int256) encode to 32 bytes in encode_data.
pub fn hash_struct_arguments(
    type_hash: [u8; 32],
    args: [Field; MAX_SERIALIZED_ARGS],
    args_len: u32,
) -> [u8; 32] {
    // Max size: type_hash(32) + 20 args * 32 bytes = 672 bytes
    let mut data: [u8; 672] = [0; 672];

    for i in 0..32 {
        data[i] = type_hash[i];
    }

    for i in 0..MAX_SERIALIZED_ARGS {
        if i < args_len {
            let arg_bytes: [u8; 32] = args[i].to_be_bytes();
            for j in 0..32 {
                data[32 + i * 32 + j] = arg_bytes[j];
            }
        }
    }

    let total_len = 32 + args_len * 32;
    keccak256(data, total_len)
}

/// Build encode_type for FunctionCall:
/// FC_PRIMARY + Arguments_DEF
pub fn build_encode_type_fc(
    args_type_string: [u8; MAX_ARGS_TYPE_STRING_LEN],
    args_type_len: u32,
) -> ([u8; 512], u32) {
    let mut result: [u8; 512] = [0; 512];
    let total_len = FC_PRIMARY_LEN + args_type_len;

    for i in 0..FC_PRIMARY_LEN {
        result[i] = FC_PRIMARY[i];
    }

    for i in 0..MAX_ARGS_TYPE_STRING_LEN {
        if i < args_type_len {
            result[FC_PRIMARY_LEN + i] = args_type_string[i];
        }
    }

    (result, total_len)
}

/// Compute hashStruct(FunctionCall) for V2 struct layout
pub fn hash_struct_function_call_v2(
    type_hash: [u8; 32],
    contract_addr: [u8; 32],
    sig_hash: [u8; 32],
    args_struct_hash: [u8; 32],
    is_public: bool,
    hide_msg_sender: bool,
    is_static: bool,
) -> [u8; 32] {
    // typeHash(32) + contract(32) + sig_hash(32) + args_hash(32) + isPublic(32) + hideMsgSender(32) + isStatic(32) = 224
    let mut data: [u8; 224] = [0; 224];

    for i in 0..32 {
        data[i] = type_hash[i];
    }
    for i in 0..32 {
        data[32 + i] = contract_addr[i];
    }
    for i in 0..32 {
        data[64 + i] = sig_hash[i];
    }
    for i in 0..32 {
        data[96 + i] = args_struct_hash[i];
    }
    if is_public {
        data[159] = 1;
    }
    if hide_msg_sender {
        data[191] = 1;
    }
    if is_static {
        data[223] = 1;
    }

    keccak256(data, 224)
}

/// Compute hashStruct(AccountData)
pub fn hash_struct_account_data(
    address: [u8; 32],
    wallet_name: [u8; MAX_SIGNATURE_SIZE],
    wallet_name_len: u32,
    version: [u8; 32],
    version_len: u32,
) -> [u8; 32] {
    let wallet_name_hash = hash_string(wallet_name, wallet_name_len);
    let version_hash = hash_string(version, version_len);

    // typeHash(32) + address(32) + walletNameHash(32) + versionHash(32) = 128
    let mut data: [u8; 128] = [0; 128];
    for i in 0..32 {
        data[i] = ACCOUNT_DATA_TYPE_HASH[i];
    }
    for i in 0..32 {
        data[32 + i] = address[i];
    }
    for i in 0..32 {
        data[64 + i] = wallet_name_hash[i];
    }
    for i in 0..32 {
        data[96 + i] = version_hash[i];
    }

    keccak256(data, 128)
}

/// Compute hashStruct(TxMetadata)
pub fn hash_struct_tx_metadata(
    fee_payment_method: u8,
    cancellable: bool,
    tx_nonce: [u8; 32],
) -> [u8; 32] {
    // typeHash(32) + feePaymentMethod(32) + cancellable(32) + txNonce(32) = 128
    let mut data: [u8; 128] = [0; 128];
    for i in 0..32 {
        data[i] = TX_METADATA_TYPE_HASH[i];
    }
    // feePaymentMethod as uint8 in 32-byte encoding
    data[63] = fee_payment_method;
    // cancellable as bool in 32-byte encoding
    if cancellable {
        data[95] = 1;
    }
    for i in 0..32 {
        data[96 + i] = tx_nonce[i];
    }

    keccak256(data, 128)
}

/// Compute hashStruct(AuthwitAppDomain)
pub fn hash_struct_authwit_app_domain(chain_id: [u8; 32], verifying_contract: [u8; 32]) -> [u8; 32] {
    let mut data: [u8; 96] = [0; 96];
    for i in 0..32 {
        data[i] = AUTHWIT_APP_DOMAIN_TYPE_HASH[i];
    }
    for i in 0..32 {
        data[32 + i] = chain_id[i];
    }
    for i in 0..32 {
        data[64 + i] = verifying_contract[i];
    }
    keccak256(data, 96)
}

/// Build the full encode_type for EntrypointAuthorization (unified).
/// = PRIMARY + AccountData_DEF + Args_DEF + FC_PRIMARY + TxMetadata_DEF
/// (referenced types in alphabetical order: AccountData, Arguments, FunctionCall, TxMetadata)
pub fn build_encode_type_entrypoint(
    args_def: [u8; MAX_ARGS_TYPE_STRING_LEN],
    args_len: u32,
) -> ([u8; 1024], u32) {
    let mut result: [u8; 1024] = [0; 1024];
    let mut offset: u32 = 0;

    // EntrypointAuthorization primary
    for i in 0..ENTRYPOINT_AUTH_PRIMARY_LEN {
        result[offset + i] = ENTRYPOINT_AUTH_PRIMARY[i];
    }
    offset += ENTRYPOINT_AUTH_PRIMARY_LEN;

    // AccountData definition (alphabetically first)
    for i in 0..ACCOUNT_DATA_DEF_LEN {
        result[offset + i] = ACCOUNT_DATA_DEF[i];
    }
    offset += ACCOUNT_DATA_DEF_LEN;

    // Arguments definition (single, shared)
    for i in 0..MAX_ARGS_TYPE_STRING_LEN {
        if i < args_len {
            result[offset + i] = args_def[i];
        }
    }
    offset += args_len;

    // FunctionCall primary (single, shared)
    for i in 0..FC_PRIMARY_LEN {
        result[offset + i] = FC_PRIMARY[i];
    }
    offset += FC_PRIMARY_LEN;

    // TxMetadata definition
    for i in 0..TX_METADATA_DEF_LEN {
        result[offset + i] = TX_METADATA_DEF[i];
    }
    offset += TX_METADATA_DEF_LEN;

    (result, offset)
}

/// Build the full encode_type for FunctionCallAuthorization (authwit).
/// = PRIMARY + Arguments_DEF + AuthwitAppDomain_DEF
pub fn build_encode_type_authwit(
    args_def: [u8; MAX_ARGS_TYPE_STRING_LEN],
    args_len: u32,
) -> ([u8; 512], u32) {
    let mut result: [u8; 512] = [0; 512];
    let mut offset: u32 = 0;

    // FunctionCallAuthorization primary
    for i in 0..FC_AUTH_PRIMARY_LEN {
        result[offset + i] = FC_AUTH_PRIMARY[i];
    }
    offset += FC_AUTH_PRIMARY_LEN;

    // Arguments definition (alphabetically before AuthwitAppDomain)
    for i in 0..MAX_ARGS_TYPE_STRING_LEN {
        if i < args_len {
            result[offset + i] = args_def[i];
        }
    }
    offset += args_len;

    // AuthwitAppDomain definition
    for i in 0..AUTHWIT_APP_DOMAIN_DEF_LEN {
        result[offset + i] = AUTHWIT_APP_DOMAIN_DEF[i];
    }
    offset += AUTHWIT_APP_DOMAIN_DEF_LEN;

    (result, offset)
}

/// Compute final EIP-712 payload
pub fn compute_eip712_payload(domain_separator: [u8; 32], message_hash: [u8; 32]) -> [u8; 32] {
    let mut payload: [u8; 66] = [0; 66];
    payload[0] = 0x19;
    payload[1] = 0x01;
    for i in 0..32 {
        payload[2 + i] = domain_separator[i];
    }
    for i in 0..32 {
        payload[34 + i] = message_hash[i];
    }
    keccak256(payload, 66)
}

// =============================================================================
// Aztec Poseidon2 Hash Functions (for AppPayload verification)
// =============================================================================

pub fn compute_aztec_args_hash(
    args: [Field; MAX_SERIALIZED_ARGS],
    len: u32,
    is_public: bool,
    selector: Field,
) -> Field {
    if is_public {
        let mut input: [Field; 22] = [0; 22];
        let generator_index = DOM_SEP__PUBLIC_CALLDATA;
        input[0] = generator_index as Field;
        input[1] = selector;
        for i in 0..MAX_SERIALIZED_ARGS {
            input[i + 2] = args[i];
        }
        let message_size = len + 2;
        poseidon2_hash_subarray(input, message_size)
    } else {
        if len == 0 {
            0
        } else {
            let mut input: [Field; 21] = [0; 21];
            let generator_index = DOM_SEP__FUNCTION_ARGS;
            input[0] = generator_index as Field;
            for i in 0..MAX_SERIALIZED_ARGS {
                input[i + 1] = args[i];
            }
            let message_size = len + 1;
            poseidon2_hash_subarray(input, message_size)
        }
    }
}

pub fn compute_function_selector(signature: [u8; MAX_SIGNATURE_SIZE], len: u32) -> u32 {
    if len == 0 {
        0
    } else {
        let mut fields: [Field; 5] = [0; 5];
        let mut field_index: u32 = 0;
        let mut current_field: [u8; 31] = [0; 31];

        for i in 0..MAX_SIGNATURE_SIZE {
            if i < len {
                let index = i % 31;
                current_field[index] = signature[i];
                if index == 30 {
                    fields[field_index] = field_from_bytes_31_le(current_field);
                    current_field = [0; 31];
                    field_index += 1;
                }
            }
        }

        let remaining = len % 31;
        if remaining != 0 {
            fields[field_index] = field_from_bytes_31_le(current_field);
            field_index += 1;
        }

        let hash = poseidon2_hash_subarray(fields, field_index);
        hash as u32
    }
}

fn field_from_bytes_31_le(bytes: [u8; 31]) -> Field {
    let mut as_field: Field = 0;
    let mut offset: Field = 1;
    for i in 0..31 {
        as_field += (bytes[i] as Field) * offset;
        offset *= 256;
    }
    as_field
}

pub fn compute_inner_hash(caller: Field, selector: u32, args_hash: Field) -> Field {
    poseidon2_hash_with_separator(
        [caller, selector as Field, args_hash],
        DOM_SEP__AUTHWIT_INNER,
    )
}

// =============================================================================
// AppPayload Serialization Helpers
// =============================================================================

pub global APP_PAYLOAD_SERIALIZED_LEN: u32 = 25; // 4 calls * 6 fields + tx_nonce
pub global FUNCTION_CALL_SERIALIZED_LEN: u32 = 6;

pub fn extract_args_hash(serialized: [Field; APP_PAYLOAD_SERIALIZED_LEN], call_index: u32) -> Field {
    let offset = call_index * FUNCTION_CALL_SERIALIZED_LEN;
    serialized[offset]
}

pub fn extract_function_selector(serialized: [Field; APP_PAYLOAD_SERIALIZED_LEN], call_index: u32) -> u32 {
    let offset = call_index * FUNCTION_CALL_SERIALIZED_LEN + 1;
    serialized[offset] as u32
}

pub fn extract_target_address(serialized: [Field; APP_PAYLOAD_SERIALIZED_LEN], call_index: u32) -> Field {
    let offset = call_index * FUNCTION_CALL_SERIALIZED_LEN + 2;
    serialized[offset]
}

pub fn extract_is_public(serialized: [Field; APP_PAYLOAD_SERIALIZED_LEN], call_index: u32) -> bool {
    let offset = call_index * FUNCTION_CALL_SERIALIZED_LEN + 3;
    serialized[offset] == 1
}
