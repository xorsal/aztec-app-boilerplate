// =============================================================================
// V2 Authwit Witness Structure (unchanged - authwit is always single-call)
// =============================================================================

/// EIP-712 V2 witness data for individual authorization (authwit)
pub struct Eip712AuthwitWitnessV2 {
    pub signature_r: [u8; 32],
    pub signature_s: [u8; 32],

    pub function_signature: [u8; MAX_SIGNATURE_SIZE],
    pub signature_length: u32,
    pub function_args: [Field; MAX_SERIALIZED_ARGS],
    pub args_length: u32,
    pub target_address: Field,
    pub is_public: bool,

    // Variable args type info
    pub args_type_string: [u8; MAX_ARGS_TYPE_STRING_LEN],
    pub args_type_string_length: u32,

    // Merkle proof
    pub merkle_proof: [Field; MERKLE_DEPTH],
    pub merkle_leaf_index: Field,

    // Authwit-specific domain
    pub chain_id: Field,
    pub verifying_contract: Field,
    pub inner_hash: Field,

    // Pre-computed type hashes from oracle
    pub fc_auth_type_hash: [u8; 32],
    pub args_type_hash: [u8; 32],
}

pub global EIP712_AUTHWIT_V2_SERIALIZED_LEN: u32 = 67;

impl Serialize for Eip712AuthwitWitnessV2 {
    let N: u32 = EIP712_AUTHWIT_V2_SERIALIZED_LEN;

    fn serialize(self) -> [Field; Self::N] {
        let mut result: [Field; EIP712_AUTHWIT_V2_SERIALIZED_LEN] = [0; EIP712_AUTHWIT_V2_SERIALIZED_LEN];

        // [0-2]: Signature
        result[0] = pack_bytes_31(self.signature_r, 0);
        let mut combined: [u8; 31] = [0; 31];
        combined[0] = self.signature_r[31];
        for i in 0..30 {
            combined[i + 1] = self.signature_s[i];
        }
        result[1] = pack_bytes_to_field(combined);
        result[2] = (self.signature_s[30] as Field) * 256 + (self.signature_s[31] as Field);

        // [3-7]: Function signature
        for i in 0..4 {
            let mut chunk: [u8; 31] = [0; 31];
            for j in 0..31 {
                chunk[j] = self.function_signature[i * 31 + j];
            }
            result[3 + i] = pack_bytes_to_field(chunk);
        }
        let mut last_chunk: Field = 0;
        for i in 0..4 {
            last_chunk = last_chunk * 256 + (self.function_signature[124 + i] as Field);
        }
        result[7] = last_chunk;

        // [8]: Signature length
        result[8] = self.signature_length as Field;

        // [9-28]: Function args
        for i in 0..MAX_SERIALIZED_ARGS {
            result[9 + i] = self.function_args[i];
        }

        // [29]: Args length
        result[29] = self.args_length as Field;

        // [30]: Target address
        result[30] = self.target_address;

        // [31]: is_public
        result[31] = self.is_public as Field;

        // [32-40]: Args type string (9 fields: 8x31 + 1x8)
        for i in 0..8 {
            let mut chunk: [u8; 31] = [0; 31];
            for j in 0..31 {
                chunk[j] = self.args_type_string[i * 31 + j];
            }
            result[32 + i] = pack_bytes_to_field(chunk);
        }
        let mut last_ts: Field = 0;
        for i in 0..8 {
            last_ts = last_ts * 256 + (self.args_type_string[248 + i] as Field);
        }
        result[40] = last_ts;

        // [41]: Args type string length
        result[41] = self.args_type_string_length as Field;

        // [42-58]: Merkle proof
        for i in 0..MERKLE_DEPTH {
            result[42 + i] = self.merkle_proof[i];
        }

        // [59]: Merkle leaf index
        result[59] = self.merkle_leaf_index;

        // [60]: Chain ID
        result[60] = self.chain_id;

        // [61]: Verifying contract
        result[61] = self.verifying_contract;

        // [62]: Inner hash
        result[62] = self.inner_hash;

        // [63-64]: fc_auth_type_hash
        result[63] = pack_bytes_31(self.fc_auth_type_hash, 0);
        result[64] = self.fc_auth_type_hash[31] as Field;

        // [65-66]: args_type_hash
        result[65] = pack_bytes_31(self.args_type_hash, 0);
        result[66] = self.args_type_hash[31] as Field;

        result
    }

    fn stream_serialize<let K: u32>(self, writer: &mut Writer<K>) {
        let serialized = self.serialize();
        writer.write_array(serialized);
    }
}

impl Deserialize for Eip712AuthwitWitnessV2 {
    let N: u32 = EIP712_AUTHWIT_V2_SERIALIZED_LEN;

    fn deserialize(fields: [Field; Self::N]) -> Self {
        let sig_bytes = unpack_signature_from_fields([fields[0], fields[1], fields[2]]);
        let mut signature_r: [u8; 32] = [0; 32];
        let mut signature_s: [u8; 32] = [0; 32];
        for i in 0..32 {
            signature_r[i] = sig_bytes[i];
            signature_s[i] = sig_bytes[32 + i];
        }

        let function_signature = unpack_func_sig_from_fields([fields[3], fields[4], fields[5], fields[6], fields[7]]);
        let signature_length = fields[8] as u32;

        let mut function_args: [Field; MAX_SERIALIZED_ARGS] = [0; MAX_SERIALIZED_ARGS];
        for i in 0..MAX_SERIALIZED_ARGS {
            function_args[i] = fields[9 + i];
        }
        let args_length = fields[29] as u32;
        let target_address = fields[30];
        let is_public = fields[31] == 1;

        // Args type string
        let mut args_type_string: [u8; MAX_ARGS_TYPE_STRING_LEN] = [0; MAX_ARGS_TYPE_STRING_LEN];
        for i in 0..8 {
            let bytes: [u8; 31] = fields[32 + i].to_be_bytes();
            for j in 0..31 {
                args_type_string[i * 31 + j] = bytes[j];
            }
        }
        let last_ts: [u8; 8] = fields[40].to_be_bytes();
        for i in 0..8 {
            args_type_string[248 + i] = last_ts[i];
        }
        let args_type_string_length = fields[41] as u32;

        let mut merkle_proof: [Field; MERKLE_DEPTH] = [0; MERKLE_DEPTH];
        for i in 0..MERKLE_DEPTH {
            merkle_proof[i] = fields[42 + i];
        }
        let merkle_leaf_index = fields[59];

        let chain_id = fields[60];
        let verifying_contract = fields[61];
        let inner_hash = fields[62];

        let fc_auth_th: [u8; 31] = fields[63].to_be_bytes();
        let mut fc_auth_type_hash: [u8; 32] = [0; 32];
        for i in 0..31 {
            fc_auth_type_hash[i] = fc_auth_th[i];
        }
        fc_auth_type_hash[31] = fields[64].to_be_bytes::<32>()[31];

        let args_th: [u8; 31] = fields[65].to_be_bytes();
        let mut args_type_hash: [u8; 32] = [0; 32];
        for i in 0..31 {
            args_type_hash[i] = args_th[i];
        }
        args_type_hash[31] = fields[66].to_be_bytes::<32>()[31];

        Eip712AuthwitWitnessV2 {
            signature_r,
            signature_s,
            function_signature,
            signature_length,
            function_args,
            args_length,
            target_address,
            is_public,
            args_type_string,
            args_type_string_length,
            merkle_proof,
            merkle_leaf_index,
            chain_id,
            verifying_contract,
            inner_hash,
            fc_auth_type_hash,
            args_type_hash,
        }
    }

    fn stream_deserialize<let K: u32>(reader: &mut Reader<K>) -> Self {
        let fields: [Field; EIP712_AUTHWIT_V2_SERIALIZED_LEN] = reader.read_array();
        Deserialize::deserialize(fields)
    }
}

/// Load V2 authwit witness from capsule storage
pub unconstrained fn load_eip712_authwit_witness_v2(
    contract_address: ::aztec::protocol::address::AztecAddress,
) -> Option<Eip712AuthwitWitnessV2> {
    capsules::load(contract_address, EIP712_AUTHWIT_V2_SLOT)
}

// =============================================================================
// Serialization Helpers (shared across all witness types)
// =============================================================================

fn pack_bytes_31<let N: u32>(bytes: [u8; N], offset: u32) -> Field {
    let mut result: Field = 0;
    for i in 0..31 {
        if offset + i < N {
            result = result * 256 + (bytes[offset + i] as Field);
        }
    }
    result
}

fn pack_bytes_to_field(bytes: [u8; 31]) -> Field {
    let mut result: Field = 0;
    for i in 0..31 {
        result = result * 256 + (bytes[i] as Field);
    }
    result
}

fn unpack_signature_from_fields(fields: [Field; 3]) -> [u8; 64] {
    let mut sig: [u8; 64] = [0; 64];
    let b0: [u8; 31] = fields[0].to_be_bytes();
    for i in 0..31 {
        sig[i] = b0[i];
    }
    let b1: [u8; 31] = fields[1].to_be_bytes();
    for i in 0..31 {
        sig[31 + i] = b1[i];
    }
    let b2: [u8; 2] = fields[2].to_be_bytes();
    sig[62] = b2[0];
    sig[63] = b2[1];
    sig
}

fn unpack_func_sig_from_fields(fields: [Field; 5]) -> [u8; MAX_SIGNATURE_SIZE] {
    let mut func_sig: [u8; MAX_SIGNATURE_SIZE] = [0; MAX_SIGNATURE_SIZE];
    for f in 0..4 {
        let bytes: [u8; 31] = fields[f].to_be_bytes();
        for i in 0..31 {
            func_sig[f * 31 + i] = bytes[i];
        }
    }
    let last: [u8; 4] = fields[4].to_be_bytes();
    for i in 0..4 {
        func_sig[124 + i] = last[i];
    }
    func_sig
}

/// Serialize ECDSA signature (r||s) into fields[0..2]
fn serialize_signature<let L: u32>(sig_r: [u8; 32], sig_s: [u8; 32], result: &mut [Field; L]) {
    result[0] = pack_bytes_31(sig_r, 0);
    let mut combined: [u8; 31] = [0; 31];
    combined[0] = sig_r[31];
    for i in 0..30 {
        combined[i + 1] = sig_s[i];
    }
    result[1] = pack_bytes_to_field(combined);
    result[2] = (sig_s[30] as Field) * 256 + (sig_s[31] as Field);
}

/// Deserialize ECDSA signature from 3 fields
fn deserialize_signature(f0: Field, f1: Field, f2: Field) -> ([u8; 32], [u8; 32]) {
    let sig_bytes = unpack_signature_from_fields([f0, f1, f2]);
    let mut signature_r: [u8; 32] = [0; 32];
    let mut signature_s: [u8; 32] = [0; 32];
    for i in 0..32 {
        signature_r[i] = sig_bytes[i];
        signature_s[i] = sig_bytes[32 + i];
    }
    (signature_r, signature_s)
}

/// Serialize one call data block (32 fields) at call_base + call_idx*32
fn serialize_call_data<let L: u32, let NC: u32>(
    call_idx: u32,
    call_base: u32,
    func_sigs: [[u8; MAX_SIGNATURE_SIZE]; NC],
    sig_lens: [u32; NC],
    func_args: [[Field; MAX_SERIALIZED_ARGS]; NC],
    args_lens: [u32; NC],
    targets: [Field; NC],
    is_pub: [bool; NC],
    hide_msg: [bool; NC],
    is_stat: [bool; NC],
    result: &mut [Field; L],
) {
    let base = call_base + call_idx * 32;
    for i in 0..4 {
        let mut chunk: [u8; 31] = [0; 31];
        for j in 0..31 {
            chunk[j] = func_sigs[call_idx][i * 31 + j];
        }
        result[base + i] = pack_bytes_to_field(chunk);
    }
    let mut last_chunk: Field = 0;
    for i in 0..4 {
        last_chunk = last_chunk * 256 + (func_sigs[call_idx][124 + i] as Field);
    }
    result[base + 4] = last_chunk;
    result[base + 5] = sig_lens[call_idx] as Field;
    for i in 0..MAX_SERIALIZED_ARGS {
        result[base + 6 + i] = func_args[call_idx][i];
    }
    result[base + 26] = args_lens[call_idx] as Field;
    result[base + 27] = targets[call_idx];
    result[base + 28] = is_pub[call_idx] as Field;
    result[base + 29] = hide_msg[call_idx] as Field;
    result[base + 30] = is_stat[call_idx] as Field;
    result[base + 31] = 0;
}

/// Serialize one type/proof block (32 fields) at tp_base + call_idx*32
fn serialize_type_proof_data<let L: u32, let NC: u32>(
    call_idx: u32,
    tp_base: u32,
    ats: [[u8; MAX_ARGS_TYPE_STRING_LEN]; NC],
    ats_lens: [u32; NC],
    mproofs: [[Field; MERKLE_DEPTH]; NC],
    mleaf_idxs: [Field; NC],
    fc_ths: [[u8; 32]; NC],
    args_ths: [[u8; 32]; NC],
    result: &mut [Field; L],
) {
    let base = tp_base + call_idx * 32;
    // Args type string (256 bytes = 9 fields: 8*31 + 1*8)
    for i in 0..8 {
        let mut chunk: [u8; 31] = [0; 31];
        for j in 0..31 {
            chunk[j] = ats[call_idx][i * 31 + j];
        }
        result[base + i] = pack_bytes_to_field(chunk);
    }
    let mut last_ts: Field = 0;
    for i in 0..8 {
        last_ts = last_ts * 256 + (ats[call_idx][248 + i] as Field);
    }
    result[base + 8] = last_ts;
    result[base + 9] = ats_lens[call_idx] as Field;
    // Merkle proof (17 fields)
    for i in 0..MERKLE_DEPTH {
        result[base + 10 + i] = mproofs[call_idx][i];
    }
    result[base + 27] = mleaf_idxs[call_idx];
    // FC type hash (31+1)
    result[base + 28] = pack_bytes_31(fc_ths[call_idx], 0);
    result[base + 29] = fc_ths[call_idx][31] as Field;
    // Args type hash (31+1)
    result[base + 30] = pack_bytes_31(args_ths[call_idx], 0);
    result[base + 31] = args_ths[call_idx][31] as Field;
}

/// Serialize metadata block (12 fields) at meta_base
fn serialize_metadata<let L: u32>(
    meta_base: u32,
    wallet_name: [u8; MAX_SIGNATURE_SIZE],
    wallet_name_length: u32,
    wallet_version: [u8; 32],
    wallet_version_length: u32,
    account_address: Field,
    chain_id: Field,
    result: &mut [Field; L],
) {
    for i in 0..4 {
        let mut chunk: [u8; 31] = [0; 31];
        for j in 0..31 {
            chunk[j] = wallet_name[i * 31 + j];
        }
        result[meta_base + i] = pack_bytes_to_field(chunk);
    }
    let mut wn_last: Field = 0;
    for i in 0..4 {
        wn_last = wn_last * 256 + (wallet_name[124 + i] as Field);
    }
    result[meta_base + 4] = wn_last;
    result[meta_base + 5] = wallet_name_length as Field;
    result[meta_base + 6] = pack_bytes_31(wallet_version, 0);
    result[meta_base + 7] = wallet_version[31] as Field;
    result[meta_base + 8] = wallet_version_length as Field;
    result[meta_base + 9] = account_address;
    result[meta_base + 10] = chain_id;
    result[meta_base + 11] = 0;
}

/// Deserialize metadata from 12 consecutive fields
fn deserialize_metadata(
    f0: Field, f1: Field, f2: Field, f3: Field, f4: Field, f5: Field,
    f6: Field, f7: Field, f8: Field, f9: Field, f10: Field, _f11: Field,
) -> ([u8; MAX_SIGNATURE_SIZE], u32, [u8; 32], u32, Field, Field) {
    let mut wallet_name: [u8; MAX_SIGNATURE_SIZE] = [0; MAX_SIGNATURE_SIZE];
    let wn = unpack_func_sig_from_fields([f0, f1, f2, f3, f4]);
    for i in 0..MAX_SIGNATURE_SIZE {
        wallet_name[i] = wn[i];
    }
    let wallet_name_length = f5 as u32;

    let mut wallet_version: [u8; 32] = [0; 32];
    let wv_bytes: [u8; 31] = f6.to_be_bytes();
    for i in 0..31 {
        wallet_version[i] = wv_bytes[i];
    }
    wallet_version[31] = f7.to_be_bytes::<32>()[31];
    let wallet_version_length = f8 as u32;

    let account_address = f9;
    let chain_id = f10;

    (wallet_name, wallet_name_length, wallet_version, wallet_version_length, account_address, chain_id)
}

/// Deserialize one type/proof block from fields at tp_base into mutable arrays at call_idx
fn deserialize_type_proof_block<let L: u32, let NC: u32>(
    fields: [Field; L],
    tp_base: u32,
    call_idx: u32,
    args_type_strings: &mut [[u8; MAX_ARGS_TYPE_STRING_LEN]; NC],
    args_type_string_lengths: &mut [u32; NC],
    merkle_proofs: &mut [[Field; MERKLE_DEPTH]; NC],
    merkle_leaf_indices: &mut [Field; NC],
    fc_type_hashes: &mut [[u8; 32]; NC],
    args_type_hashes: &mut [[u8; 32]; NC],
) {
    // Args type string (9 fields: 8*31 + 1*8)
    for i in 0..8 {
        let bytes: [u8; 31] = fields[tp_base + i].to_be_bytes();
        for j in 0..31 {
            args_type_strings[call_idx][i * 31 + j] = bytes[j];
        }
    }
    let last_ts: [u8; 8] = fields[tp_base + 8].to_be_bytes();
    for i in 0..8 {
        args_type_strings[call_idx][248 + i] = last_ts[i];
    }
    args_type_string_lengths[call_idx] = fields[tp_base + 9] as u32;

    // Merkle proof
    for i in 0..MERKLE_DEPTH {
        merkle_proofs[call_idx][i] = fields[tp_base + 10 + i];
    }
    merkle_leaf_indices[call_idx] = fields[tp_base + 27];

    // FC type hash (31+1)
    let fc_th_bytes: [u8; 31] = fields[tp_base + 28].to_be_bytes();
    for j in 0..31 {
        fc_type_hashes[call_idx][j] = fc_th_bytes[j];
    }
    fc_type_hashes[call_idx][31] = fields[tp_base + 29].to_be_bytes::<32>()[31];

    // Args type hash (31+1)
    let args_th_bytes: [u8; 31] = fields[tp_base + 30].to_be_bytes();
    for j in 0..31 {
        args_type_hashes[call_idx][j] = args_th_bytes[j];
    }
    args_type_hashes[call_idx][31] = fields[tp_base + 31].to_be_bytes::<32>()[31];
}

// =============================================================================
// EIP-712 V2 Hash Functions
// =============================================================================

/// Hash a dynamic-length string for EIP-712 encoding: enc(string) = keccak256(string)
pub fn hash_string<let N: u32>(data: [u8; N], len: u32) -> [u8; 32] {
    keccak256(data, len)
}

/// Convert a Field to 32-byte big-endian representation
pub fn field_to_bytes32(f: Field) -> [u8; 32] {
    f.to_be_bytes()
}

/// Compute type_hash from a type string: keccak256(type_string)
pub fn compute_type_hash<let N: u32>(type_string: [u8; N], len: u32) -> [u8; 32] {
    keccak256(type_string, len)
}

/// Convert a 32-byte type_hash to a Field for Merkle tree lookup.
pub fn type_hash_to_field(type_hash: [u8; 32]) -> Field {
    let mut result: Field = 0;
    for i in 0..32 {
        result = result * 256 + (type_hash[i] as Field);
    }
    result
}

/// Verify that a type_hash is in the Merkle tree whitelist
pub fn verify_arguments_whitelist(
    type_hash_field: Field,
    proof: [Field; MERKLE_DEPTH],
    leaf_index: Field,
    root: Field,
) {
    let witness = MembershipWitness { leaf_index, sibling_path: proof };
    assert(
        check_membership(type_hash_field, witness, root),
        "Arguments type_hash not in whitelist",
    );
}

/// Compute hashStruct(Arguments) with variable types.
/// All types (bytes32, uint256, address) encode to 32 bytes in encode_data.
pub fn hash_struct_arguments(
    type_hash: [u8; 32],
    args: [Field; MAX_SERIALIZED_ARGS],
    args_len: u32,
) -> [u8; 32] {
    // Max size: type_hash(32) + 20 args * 32 bytes = 672 bytes
    let mut data: [u8; 672] = [0; 672];

    for i in 0..32 {
        data[i] = type_hash[i];
    }

    for i in 0..MAX_SERIALIZED_ARGS {
        if i < args_len {
            let arg_bytes: [u8; 32] = args[i].to_be_bytes();
            for j in 0..32 {
                data[32 + i * 32 + j] = arg_bytes[j];
            }
        }
    }

    let total_len = 32 + args_len * 32;
    keccak256(data, total_len)
}

/// Build encode_type for a single FunctionCall (parameterized by FC primary)
pub fn build_encode_type_fc(
    fc_primary: [u8; 124],
    args_type_string: [u8; MAX_ARGS_TYPE_STRING_LEN],
    args_type_len: u32,
) -> ([u8; 512], u32) {
    let mut result: [u8; 512] = [0; 512];
    let total_len = 124 + args_type_len;

    for i in 0..124 {
        result[i] = fc_primary[i];
    }

    for i in 0..MAX_ARGS_TYPE_STRING_LEN {
        if i < args_type_len {
            result[124 + i] = args_type_string[i];
        }
    }

    (result, total_len)
}

/// Compute hashStruct(FunctionCall) for V2 struct layout
pub fn hash_struct_function_call_v2(
    type_hash: [u8; 32],
    contract_addr: [u8; 32],
    sig_hash: [u8; 32],
    args_struct_hash: [u8; 32],
    is_public: bool,
    hide_msg_sender: bool,
    is_static: bool,
) -> [u8; 32] {
    // typeHash(32) + contract(32) + sig_hash(32) + args_hash(32) + isPublic(32) + hideMsgSender(32) + isStatic(32) = 224
    let mut data: [u8; 224] = [0; 224];

    for i in 0..32 {
        data[i] = type_hash[i];
    }
    for i in 0..32 {
        data[32 + i] = contract_addr[i];
    }
    for i in 0..32 {
        data[64 + i] = sig_hash[i];
    }
    for i in 0..32 {
        data[96 + i] = args_struct_hash[i];
    }
    if is_public {
        data[159] = 1;
    }
    if hide_msg_sender {
        data[191] = 1;
    }
    if is_static {
        data[223] = 1;
    }

    keccak256(data, 224)
}

/// Compute hashStruct(AccountData)
pub fn hash_struct_account_data(
    address: [u8; 32],
    wallet_name: [u8; MAX_SIGNATURE_SIZE],
    wallet_name_len: u32,
    version: [u8; 32],
    version_len: u32,
) -> [u8; 32] {
    let wallet_name_hash = hash_string(wallet_name, wallet_name_len);
    let version_hash = hash_string(version, version_len);

    // typeHash(32) + address(32) + walletNameHash(32) + versionHash(32) = 128
    let mut data: [u8; 128] = [0; 128];
    for i in 0..32 {
        data[i] = ACCOUNT_DATA_TYPE_HASH[i];
    }
    for i in 0..32 {
        data[32 + i] = address[i];
    }
    for i in 0..32 {
        data[64 + i] = wallet_name_hash[i];
    }
    for i in 0..32 {
        data[96 + i] = version_hash[i];
    }

    keccak256(data, 128)
}

/// Compute hashStruct(TxMetadata)
pub fn hash_struct_tx_metadata(
    fee_payment_method: u8,
    cancellable: bool,
    tx_nonce: [u8; 32],
) -> [u8; 32] {
    // typeHash(32) + feePaymentMethod(32) + cancellable(32) + txNonce(32) = 128
    let mut data: [u8; 128] = [0; 128];
    for i in 0..32 {
        data[i] = TX_METADATA_TYPE_HASH[i];
    }
    // feePaymentMethod as uint8 in 32-byte encoding
    data[63] = fee_payment_method;
    // cancellable as bool in 32-byte encoding
    if cancellable {
        data[95] = 1;
    }
    for i in 0..32 {
        data[96 + i] = tx_nonce[i];
    }

    keccak256(data, 128)
}

/// Compute hashStruct(AuthwitAppDomain)
pub fn hash_struct_authwit_app_domain(chain_id: [u8; 32], verifying_contract: [u8; 32]) -> [u8; 32] {
    let mut data: [u8; 96] = [0; 96];
    for i in 0..32 {
        data[i] = AUTHWIT_APP_DOMAIN_TYPE_HASH[i];
    }
    for i in 0..32 {
        data[32 + i] = chain_id[i];
    }
    for i in 0..32 {
        data[64 + i] = verifying_contract[i];
    }
    keccak256(data, 96)
}

// =============================================================================
// Per-N encode_type builders for EntrypointAuthorization
// =============================================================================

/// Build encode_type for EntrypointAuthorization with 1 call
pub fn build_encode_type_entrypoint_1(
    args_def_1: [u8; MAX_ARGS_TYPE_STRING_LEN],
    args_len_1: u32,
) -> ([u8; 2048], u32) {
    let mut result: [u8; 2048] = [0; 2048];
    let mut offset: u32 = 0;

    for i in 0..ENTRYPOINT_AUTH_PRIMARY_1_LEN { result[offset + i] = ENTRYPOINT_AUTH_PRIMARY_1[i]; }
    offset += ENTRYPOINT_AUTH_PRIMARY_1_LEN;

    for i in 0..ACCOUNT_DATA_DEF_LEN { result[offset + i] = ACCOUNT_DATA_DEF[i]; }
    offset += ACCOUNT_DATA_DEF_LEN;

    for i in 0..MAX_ARGS_TYPE_STRING_LEN { if i < args_len_1 { result[offset + i] = args_def_1[i]; } }
    offset += args_len_1;

    for i in 0..FC1_PRIMARY_LEN { result[offset + i] = FC1_PRIMARY[i]; }
    offset += FC1_PRIMARY_LEN;

    for i in 0..TX_METADATA_DEF_LEN { result[offset + i] = TX_METADATA_DEF[i]; }
    offset += TX_METADATA_DEF_LEN;

    (result, offset)
}

/// Build encode_type for EntrypointAuthorization with 2 calls
pub fn build_encode_type_entrypoint_2(
    args_def_1: [u8; MAX_ARGS_TYPE_STRING_LEN], args_len_1: u32,
    args_def_2: [u8; MAX_ARGS_TYPE_STRING_LEN], args_len_2: u32,
) -> ([u8; 2048], u32) {
    let mut result: [u8; 2048] = [0; 2048];
    let mut offset: u32 = 0;

    for i in 0..ENTRYPOINT_AUTH_PRIMARY_2_LEN { result[offset + i] = ENTRYPOINT_AUTH_PRIMARY_2[i]; }
    offset += ENTRYPOINT_AUTH_PRIMARY_2_LEN;

    for i in 0..ACCOUNT_DATA_DEF_LEN { result[offset + i] = ACCOUNT_DATA_DEF[i]; }
    offset += ACCOUNT_DATA_DEF_LEN;

    for i in 0..MAX_ARGS_TYPE_STRING_LEN { if i < args_len_1 { result[offset + i] = args_def_1[i]; } }
    offset += args_len_1;
    for i in 0..MAX_ARGS_TYPE_STRING_LEN { if i < args_len_2 { result[offset + i] = args_def_2[i]; } }
    offset += args_len_2;

    for i in 0..FC1_PRIMARY_LEN { result[offset + i] = FC1_PRIMARY[i]; }
    offset += FC1_PRIMARY_LEN;
    for i in 0..FC2_PRIMARY_LEN { result[offset + i] = FC2_PRIMARY[i]; }
    offset += FC2_PRIMARY_LEN;

    for i in 0..TX_METADATA_DEF_LEN { result[offset + i] = TX_METADATA_DEF[i]; }
    offset += TX_METADATA_DEF_LEN;

    (result, offset)
}

/// Build encode_type for EntrypointAuthorization with 3 calls
pub fn build_encode_type_entrypoint_3(
    args_def_1: [u8; MAX_ARGS_TYPE_STRING_LEN], args_len_1: u32,
    args_def_2: [u8; MAX_ARGS_TYPE_STRING_LEN], args_len_2: u32,
    args_def_3: [u8; MAX_ARGS_TYPE_STRING_LEN], args_len_3: u32,
) -> ([u8; 2048], u32) {
    let mut result: [u8; 2048] = [0; 2048];
    let mut offset: u32 = 0;

    for i in 0..ENTRYPOINT_AUTH_PRIMARY_3_LEN { result[offset + i] = ENTRYPOINT_AUTH_PRIMARY_3[i]; }
    offset += ENTRYPOINT_AUTH_PRIMARY_3_LEN;

    for i in 0..ACCOUNT_DATA_DEF_LEN { result[offset + i] = ACCOUNT_DATA_DEF[i]; }
    offset += ACCOUNT_DATA_DEF_LEN;

    for i in 0..MAX_ARGS_TYPE_STRING_LEN { if i < args_len_1 { result[offset + i] = args_def_1[i]; } }
    offset += args_len_1;
    for i in 0..MAX_ARGS_TYPE_STRING_LEN { if i < args_len_2 { result[offset + i] = args_def_2[i]; } }
    offset += args_len_2;
    for i in 0..MAX_ARGS_TYPE_STRING_LEN { if i < args_len_3 { result[offset + i] = args_def_3[i]; } }
    offset += args_len_3;

    for i in 0..FC1_PRIMARY_LEN { result[offset + i] = FC1_PRIMARY[i]; }
    offset += FC1_PRIMARY_LEN;
    for i in 0..FC2_PRIMARY_LEN { result[offset + i] = FC2_PRIMARY[i]; }
    offset += FC2_PRIMARY_LEN;
    for i in 0..FC3_PRIMARY_LEN { result[offset + i] = FC3_PRIMARY[i]; }
    offset += FC3_PRIMARY_LEN;

    for i in 0..TX_METADATA_DEF_LEN { result[offset + i] = TX_METADATA_DEF[i]; }
    offset += TX_METADATA_DEF_LEN;

    (result, offset)
}

/// Build encode_type for EntrypointAuthorization with 4 calls
pub fn build_encode_type_entrypoint_4(
    args_def_1: [u8; MAX_ARGS_TYPE_STRING_LEN], args_len_1: u32,
    args_def_2: [u8; MAX_ARGS_TYPE_STRING_LEN], args_len_2: u32,
    args_def_3: [u8; MAX_ARGS_TYPE_STRING_LEN], args_len_3: u32,
    args_def_4: [u8; MAX_ARGS_TYPE_STRING_LEN], args_len_4: u32,
) -> ([u8; 2048], u32) {
    let mut result: [u8; 2048] = [0; 2048];
    let mut offset: u32 = 0;

    for i in 0..ENTRYPOINT_AUTH_PRIMARY_4_LEN { result[offset + i] = ENTRYPOINT_AUTH_PRIMARY_4[i]; }
    offset += ENTRYPOINT_AUTH_PRIMARY_4_LEN;

    for i in 0..ACCOUNT_DATA_DEF_LEN { result[offset + i] = ACCOUNT_DATA_DEF[i]; }
    offset += ACCOUNT_DATA_DEF_LEN;

    for i in 0..MAX_ARGS_TYPE_STRING_LEN { if i < args_len_1 { result[offset + i] = args_def_1[i]; } }
    offset += args_len_1;
    for i in 0..MAX_ARGS_TYPE_STRING_LEN { if i < args_len_2 { result[offset + i] = args_def_2[i]; } }
    offset += args_len_2;
    for i in 0..MAX_ARGS_TYPE_STRING_LEN { if i < args_len_3 { result[offset + i] = args_def_3[i]; } }
    offset += args_len_3;
    for i in 0..MAX_ARGS_TYPE_STRING_LEN { if i < args_len_4 { result[offset + i] = args_def_4[i]; } }
    offset += args_len_4;

    for i in 0..FC1_PRIMARY_LEN { result[offset + i] = FC1_PRIMARY[i]; }
    offset += FC1_PRIMARY_LEN;
    for i in 0..FC2_PRIMARY_LEN { result[offset + i] = FC2_PRIMARY[i]; }
    offset += FC2_PRIMARY_LEN;
    for i in 0..FC3_PRIMARY_LEN { result[offset + i] = FC3_PRIMARY[i]; }
    offset += FC3_PRIMARY_LEN;
    for i in 0..FC4_PRIMARY_LEN { result[offset + i] = FC4_PRIMARY[i]; }
    offset += FC4_PRIMARY_LEN;

    for i in 0..TX_METADATA_DEF_LEN { result[offset + i] = TX_METADATA_DEF[i]; }
    offset += TX_METADATA_DEF_LEN;

    (result, offset)
}

/// Build the full encode_type for FunctionCallAuthorization (authwit).
/// = PRIMARY + Arguments_DEF + AuthwitAppDomain_DEF
pub fn build_encode_type_authwit(
    args_def: [u8; MAX_ARGS_TYPE_STRING_LEN],
    args_len: u32,
) -> ([u8; 512], u32) {
    let mut result: [u8; 512] = [0; 512];
    let mut offset: u32 = 0;

    // FunctionCallAuthorization primary
    for i in 0..FC_AUTH_PRIMARY_LEN {
        result[offset + i] = FC_AUTH_PRIMARY[i];
    }
    offset += FC_AUTH_PRIMARY_LEN;

    // Arguments definition (alphabetically before AuthwitAppDomain)
    for i in 0..MAX_ARGS_TYPE_STRING_LEN {
        if i < args_len {
            result[offset + i] = args_def[i];
        }
    }
    offset += args_len;

    // AuthwitAppDomain definition
    for i in 0..AUTHWIT_APP_DOMAIN_DEF_LEN {
        result[offset + i] = AUTHWIT_APP_DOMAIN_DEF[i];
    }
    offset += AUTHWIT_APP_DOMAIN_DEF_LEN;

    (result, offset)
}

/// Compute final EIP-712 payload
pub fn compute_eip712_payload(domain_separator: [u8; 32], message_hash: [u8; 32]) -> [u8; 32] {
    let mut payload: [u8; 66] = [0; 66];
    payload[0] = 0x19;
    payload[1] = 0x01;
    for i in 0..32 {
        payload[2 + i] = domain_separator[i];
    }
    for i in 0..32 {
        payload[34 + i] = message_hash[i];
    }
    keccak256(payload, 66)
}

// =============================================================================
// Generic AppPayload Extract Helpers
// =============================================================================

pub fn extract_args_hash<let L: u32>(serialized: [Field; L], call_index: u32) -> Field {
    let offset = call_index * FUNCTION_CALL_SERIALIZED_LEN;
    serialized[offset]
}

pub fn extract_function_selector<let L: u32>(serialized: [Field; L], call_index: u32) -> u32 {
    let offset = call_index * FUNCTION_CALL_SERIALIZED_LEN + 1;
    serialized[offset] as u32
}

pub fn extract_target_address<let L: u32>(serialized: [Field; L], call_index: u32) -> Field {
    let offset = call_index * FUNCTION_CALL_SERIALIZED_LEN + 2;
    serialized[offset]
}

pub fn extract_is_public<let L: u32>(serialized: [Field; L], call_index: u32) -> bool {
    let offset = call_index * FUNCTION_CALL_SERIALIZED_LEN + 3;
    serialized[offset] == 1
}

// =============================================================================
// Aztec Poseidon2 Hash Functions (for AppPayload verification)
// =============================================================================

pub fn compute_aztec_args_hash(
    args: [Field; MAX_SERIALIZED_ARGS],
    len: u32,
    is_public: bool,
    selector: Field,
) -> Field {
    if is_public {
        let mut input: [Field; 22] = [0; 22];
        let generator_index = DOM_SEP__PUBLIC_CALLDATA;
        input[0] = generator_index as Field;
        input[1] = selector;
        for i in 0..MAX_SERIALIZED_ARGS {
            input[i + 2] = args[i];
        }
        let message_size = len + 2;
        poseidon2_hash_subarray(input, message_size)
    } else {
        if len == 0 {
            0
        } else {
            let mut input: [Field; 21] = [0; 21];
            let generator_index = DOM_SEP__FUNCTION_ARGS;
            input[0] = generator_index as Field;
            for i in 0..MAX_SERIALIZED_ARGS {
                input[i + 1] = args[i];
            }
            let message_size = len + 1;
            poseidon2_hash_subarray(input, message_size)
        }
    }
}

pub fn compute_function_selector(signature: [u8; MAX_SIGNATURE_SIZE], len: u32) -> u32 {
    if len == 0 {
        0
    } else {
        let mut fields: [Field; 5] = [0; 5];
        let mut field_index: u32 = 0;
        let mut current_field: [u8; 31] = [0; 31];

        for i in 0..MAX_SIGNATURE_SIZE {
            if i < len {
                let index = i % 31;
                current_field[index] = signature[i];
                if index == 30 {
                    fields[field_index] = field_from_bytes_31_le(current_field);
                    current_field = [0; 31];
                    field_index += 1;
                }
            }
        }

        let remaining = len % 31;
        if remaining != 0 {
            fields[field_index] = field_from_bytes_31_le(current_field);
            field_index += 1;
        }

        let hash = poseidon2_hash_subarray(fields, field_index);
        hash as u32
    }
}

fn field_from_bytes_31_le(bytes: [u8; 31]) -> Field {
    let mut as_field: Field = 0;
    let mut offset: Field = 1;
    for i in 0..31 {
        as_field += (bytes[i] as Field) * offset;
        offset *= 256;
    }
    as_field
}

pub fn compute_inner_hash(caller: Field, selector: u32, args_hash: Field) -> Field {
    poseidon2_hash_with_separator(
        [caller, selector as Field, args_hash],
        DOM_SEP__AUTHWIT_INNER,
    )
}
